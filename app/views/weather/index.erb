    <h5 class="mb-2 text-2xl font-bold tracking-tight text-gray-900">Meet Cloudy, your personal climatologist.</h5>
    <p class="mb-3 font-normal text-gray-700">Enter a US address and discover what the sky is up to.</p>
    <%= form_tag('/query', method: :get) do %>
        <%= text_field_tag :address, nil, placeholder: "Enter a US address to get started", class: "bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg block w-full p-2.5" %>
